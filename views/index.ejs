<%- include('partials/header') %>

<main class="main-content">
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="hero-content">
                <p class="eyebrow" data-aos="fade-up">A refined space for modern storytelling</p>
                <h1 class="hero-title" data-aos="fade-up">Every Voice Matters</h1>
                <p class="hero-subtitle" data-aos="fade-up" data-aos-delay="200">Share your opinions and perspectives on technology, politics, lifestyle, art, and more. A calm, elegant reading experience designed for curious minds.</p>
                <div class="hero-buttons" data-aos="fade-up" data-aos-delay="400">
                    <a href="/blog/list" class="btn btn-primary">Explore Blogs</a>
                    <a href="#featured-voices" class="btn btn-secondary" id="scroll-to-featured">Featured Voices</a>
                    <% if (typeof user !== 'undefined' && user) { %>
                        <a href="/blog/create/new" class="btn btn-secondary">Write Your Story</a>
                    <% } else { %>
                        <a href="/auth/signup" class="btn btn-secondary">Join Voices</a>
                    <% } %>
                </div>
                <div class="hero-metrics" data-aos="fade-up" data-aos-delay="500">
                    <article class="metric-card"><strong>100+</strong><span>Curated reads</span></article>
                    <article class="metric-card"><strong>8</strong><span>Editorial categories</span></article>
                    <article class="metric-card"><strong>24/7</strong><span>Fresh ideas</span></article>
                </div>
            </div>
        </div>
    </section>

    <section class="feature-strip container">
        <article class="feature-card" data-aos="fade-up"><h3>Thoughtful Stories</h3><p>Explore crafted articles, insights and perspectives designed for meaningful reading</p></article>
        <article class="feature-card" data-aos="fade-up" data-aos-delay="100"><h3>Fresh Perspectives</h3><p>Discover new ideas, experiences and opinions from writers across different interests and topics.</p></article>
        <article class="feature-card" data-aos="fade-up" data-aos-delay="200"><h3>Build Your Presence</h3><p>Create your personal space, grow your audience and showcase your best work.</p></article>
    </section>

    <section class="container welcome-section" data-aos="fade-up">
        <div class="welcome-grid">
            <article class="panel-card">
                <span class="topic-chip">Welcome to Voices</span>
                <h2>Share your thoughts. Explore diverse perspectives. Join the conversation.</h2>
                <p>Voices blends thoughtful editorials, fresh community prompts, and a calm reading experience into one modern reading space for curious creators.</p>
                <div class="hero-buttons" style="margin-top: 18px; justify-content: flex-start;">
                    <a href="/blog/create/new" class="btn btn-primary">Write a Post</a>
                    <a href="/weekly-question" class="btn btn-secondary">See Weekly Question</a>
                </div>
            </article>
        </div>

        <div class="welcome-grid">
            <article class="mini-card" style="margin-top: 6px;">
                <span class="topic-chip">This week</span>
                <strong>AI & Creativity</strong>
                <p>Where do human insight and machine speed meet in the stories we tell?</p>
            </article>
        </div>

        <div class="editorial-grid">
            <article class="mini-card">
                <span class="topic-chip">Featured discussions</span>
                <h3>Community-led ideas</h3>
                <p>Thoughtful prompt threads on culture, design, education, and the future of work.</p>
            </article>
            <article class="mini-card">
                <span class="topic-chip">Editor picks</span>
                <h3>Fresh reads this week</h3>
                <p>Curated conversations from writers who balance clarity, empathy, and smart perspective.</p>
            </article>
            <article class="mini-card">
                <span class="topic-chip">Trending topics</span>
                <h3>What readers are exploring</h3>
                <p>Remote work, wellbeing, AI tools, and creative confidence continue to lead the conversation.</p>
            </article>
        </div>

        <div class="spotlight-grid">
            <article class="creator-spotlight-section">
                <div class="accent-line"></div>
                <h2 class="section-heading">Creator Spotlight</h2>
                <div class="editorial-layout">
                    <div class="editorial-content">
                        <p class="editorial-intro">Meet the writer behind the next perspective</p>
                        <p class="editorial-body">Our spotlight series celebrates storytellers who turn ideas into calm, deliberate reading experiences with depth and personality. This month, we're featuring writers who blend clarity, creativity, and thoughtful perspective across diverse topics—from technology and wellness to culture and the future of work.</p>
                        <div class="spotlight-stats">
                            <div class="stat-item">
                                <strong>120+</strong>
                                <span>Featured creators</span>
                            </div>
                            <div class="stat-item">
                                <strong>8K+</strong>
                                <span>Monthly readers</span>
                            </div>
                        </div>
                        <a href="/featured" class="btn btn-primary">Explore All Creators</a>
                    </div>
                    <div class="editorial-image creator-image" aria-hidden="true"></div>
                </div>
            </article>
        </div>

        <div class="weekly-section">
            <article class="weekly-question-section">
                <div class="accent-line-warm"></div>
                <h2 class="section-heading-warm">Weekly Question</h2>
                <div class="editorial-layout editorial-layout-reverse">
                    <div class="editorial-image weekly-image" aria-hidden="true"></div>
                    <div class="editorial-content">
                        <p class="editorial-intro-warm">What would you change first in your daily routine if you had one extra hour each week?</p>
                        <p class="editorial-body">We're inviting readers to reflect on small habits, creative time, and the parts of life that deserve more care. Every response offers a glimpse into how people prioritize their time and energy—a powerful look at what matters most.</p>
                        <div class="community-stats">
                            <div class="community-item">
                                <strong>847</strong>
                                <span>Responses this week</span>
                            </div>
                            <div class="community-item">
                                <strong>12K</strong>
                                <span>Community viewers</span>
                            </div>
                        </div>
                        <div class="weekly-actions">
                            <a href="/blog/create/new" class="btn btn-primary">Share Your Answer</a>
                            <a href="/weekly-question" class="btn btn-secondary">Read All Responses</a>
                        </div>
                    </div>
                </div>
            </article>
        </div>
    </section>

    <section class="container">
        <div class="page-header" style="margin: 8px 0 32px; padding-top: 24px;">
            <h2 style="font-size: 2.3rem; text-align: left; margin-bottom: 10px;">Latest Posts</h2>
            <p style="text-align: left; font-size: 1.05rem;">Realistic sample reads designed to make the homepage feel alive and editorial.</p>
        </div>
        <div class="blogs-grid">
            <article class="blog-card" data-aos="zoom-in">
                <div class="blog-card-image"><img src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?w=900&q=90" alt="AI and creativity"></div>
                <div class="blog-card-content"><h3 class="blog-card-title"><a href="/blog/list">Is AI helping or hurting creativity?</a></h3><p class="blog-card-excerpt">A closer look at how thoughtful tools are changing the writing process and the role of human taste.</p><div class="blog-card-meta"><span class="blog-author">By Maya Stone</span><span class="blog-date">Today</span></div></div>
            </article>
            <article class="blog-card" data-aos="zoom-in" data-aos-delay="100">
                <div class="blog-card-image"><img src="https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?w=900&q=90" alt="Mental health in schools"></div>
                <div class="blog-card-content"><h3 class="blog-card-title"><a href="/blog/list">Why mental health matters in schools</a></h3><p class="blog-card-excerpt">From calm classrooms to real support systems, this piece explores how emotional wellbeing shapes learning.</p><div class="blog-card-meta"><span class="blog-author">By Jordan Lee</span><span class="blog-date">2 days ago</span></div></div>
            </article>
            <article class="blog-card" data-aos="zoom-in" data-aos-delay="200">
                <div class="blog-card-image"><img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=900&q=90" alt="Remote work after COVID"></div>
                <div class="blog-card-content"><h3 class="blog-card-title"><a href="/blog/list">Should remote work stay after COVID?</a></h3><p class="blog-card-excerpt">A modern take on flexibility, focus, and the balance between personal life and professional growth.</p><div class="blog-card-meta"><span class="blog-author">By Alex Rivera</span><span class="blog-date">This week</span></div></div>
            </article>
        </div>
    </section>

    <!-- Featured Blogs Section -->
    <section class="featured-section" id="featured-voices">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Featured Voices</h2>
            <div class="blogs-grid" id="featuredBlogsGrid" data-aos="fade-up" data-aos-delay="100">
                <% if (featuredBlogs && featuredBlogs.length > 0) { %>
                    <% featuredBlogs.forEach((blog, index) => { %>
                        <div class="home-featured-card" data-blog-id="<%= blog._id %>" data-aos="zoom-in" data-aos-delay="<%= index * 100 %>">
                            <div class="blog-card-image">
                                <img src="<%= blog.imageUrl || '/images/default-blog.jpg' %>" alt="<%= blog.title %>">
                                <span class="blog-category"><%= blog.category %></span>
                            </div>
                            <div class="blog-card-content">
                                <h3 class="blog-card-title"><a href="/blog/<%= blog._id %>"><%= blog.title %></a></h3>
                                <p class="blog-card-excerpt"><%= blog.excerpt %></p>
                                <div class="blog-card-meta">
                                    <span class="blog-author">By <%= blog.author %></span>
                                    <span class="blog-views">👁 <%= blog.views %> views</span>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="no-blogs">No featured blogs yet. Be the first to share your voice!</p>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Recent Blogs Section -->
    <section class="recent-section">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Trending Voices</h2>
            <div class="blogs-grid" id="recentBlogsGrid" data-aos="fade-up" data-aos-delay="100">
                <% if (recentBlogs && recentBlogs.length > 0) { %>
                    <% recentBlogs.forEach((blog, index) => { %>
                        <div class="blog-card" data-blog-id="<%= blog._id %>" data-aos="zoom-in" data-aos-delay="<%= index * 100 %>">
                            <div class="blog-card-image">
                                <img src="<%= blog.imageUrl || '/images/default-blog.jpg' %>" alt="<%= blog.title %>">
                                <span class="blog-category"><%= blog.category %></span>
                            </div>
                            <div class="blog-card-content">
                                <h3 class="blog-card-title"><a href="/blog/<%= blog._id %>"><%= blog.title %></a></h3>
                                <p class="blog-card-excerpt"><%= blog.excerpt %></p>
                                <div class="blog-card-meta">
                                    <span class="blog-author">By <%= blog.author %></span>
                                    <span class="blog-date"><%= new Date(blog.createdAt).toLocaleDateString() %></span>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="no-blogs">No recent blogs yet.</p>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Categories Section -->
    <section class="categories-section">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Explore by Category</h2>
            <div class="categories-grid" data-aos="fade-up" data-aos-delay="100">
                <a href="/category/Technology" class="category-card" style="--category-image: url('https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=900&q=90');" data-aos="zoom-in" data-aos-delay="0">
                    <div class="category-icon"><svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="8" y="14" width="48" height="32" rx="10" fill="url(#g1)"/><rect x="18" y="26" width="28" height="2" rx="1" fill="white" fill-opacity="0.9"/><rect x="22" y="32" width="20" height="2" rx="1" fill="white" fill-opacity="0.55"/><defs><linearGradient id="g1" x1="8" x2="56" y1="14" y2="46"><stop stop-color="#7C5CFF"/><stop offset="1" stop-color="#2DD4BF"/></linearGradient></defs></svg></div>
                    <h3>Technology</h3>
                    <p>AI, devices, and digital culture.</p>
                </a>
                <a href="/category/Politics" class="category-card" style="--category-image: url('https://images.unsplash.com/photo-1521295121783-8a321d551ad2?w=900&q=90');" data-aos="zoom-in" data-aos-delay="100">
                    <div class="category-icon"><svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M32 10L46 18V28C46 37.5 40 45.7 32 49C24 45.7 18 37.5 18 28V18L32 10Z" fill="url(#g2)"/><path d="M24 28H40" stroke="white" stroke-width="3" stroke-linecap="round"/><path d="M27 34H37" stroke="white" stroke-width="3" stroke-linecap="round"/><defs><linearGradient id="g2" x1="18" x2="46" y1="10" y2="49"><stop stop-color="#7C5CFF"/><stop offset="1" stop-color="#F472B6"/></linearGradient></defs></svg></div>
                    <h3>Politics</h3>
                    <p>Public discourse and current affairs.</p>
                </a>
                <a href="/category/Lifestyle" class="category-card" style="--category-image: url('https://images.unsplash.com/photo-1494526585095-c41746248156?w=900&q=90');" data-aos="zoom-in" data-aos-delay="200">
                    <div class="category-icon"><svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M32 10C38.2 18.6 42.6 23.6 46 27.2C49.4 30.8 52 33.7 52 38.4C52 45.7 46.2 51 39 51C35.2 51 31.4 49.5 28.8 46.9C26.2 44.3 24.6 40.7 24.6 36.9C24.6 33.8 25.4 31 26.9 28.8C29.1 25.7 32 22.8 32 10Z" fill="url(#g3)"/><path d="M24 12C18.8 20.8 14.8 25.6 12 29.2C9.2 32.8 7 35.6 7 40.3C7 47.1 12.4 52 19.2 52C22.6 52 25.9 50.9 28.5 48.8" stroke="white" stroke-width="3" stroke-linecap="round"/><defs><linearGradient id="g3" x1="7" x2="52" y1="10" y2="52"><stop stop-color="#2DD4BF"/><stop offset="1" stop-color="#7C5CFF"/></linearGradient></defs></svg></div>
                    <h3>Lifestyle</h3>
                    <p>Design, habits, and everyday inspiration.</p>
                </a>
                <a href="/category/Art" class="category-card" style="--category-image: url('https://images.unsplash.com/photo-1515405295579-ba7b45403062?w=900&q=90');" data-aos="zoom-in" data-aos-delay="300">
                    <div class="category-icon"><svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M18 46C23.8 35.5 28.3 28.6 31.6 25.2C35.1 21.6 39.3 18.7 45 16" stroke="url(#g4)" stroke-width="4" stroke-linecap="round"/><circle cx="22" cy="24" r="8" fill="url(#g4)"/><path d="M42 34L52 44" stroke="#2DD4BF" stroke-width="4" stroke-linecap="round"/><defs><linearGradient id="g4" x1="18" x2="52" y1="16" y2="46"><stop stop-color="#F472B6"/><stop offset="1" stop-color="#7C5CFF"/></linearGradient></defs></svg></div>
                    <h3>Art</h3>
                    <p>Creative direction and visual stories.</p>
                </a>
                <a href="/category/Science" class="category-card" style="--category-image: url('https://images.unsplash.com/photo-1532094349884-543bc11b234d?w=900&q=90');" data-aos="zoom-in" data-aos-delay="400">
                    <div class="category-icon"><svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M32 10C27.6 16.2 24.3 20.4 22 23.5C19.7 26.6 18 29 18 33.3C18 42 24.2 49 32 49C39.8 49 46 42 46 33.3C46 29 44.3 26.6 42 23.5C39.7 20.4 36.4 16.2 32 10Z" fill="url(#g5)"/><path d="M32 19V37" stroke="white" stroke-width="3" stroke-linecap="round"/><path d="M25 27H39" stroke="white" stroke-width="3" stroke-linecap="round"/><defs><linearGradient id="g5" x1="18" x2="46" y1="10" y2="49"><stop stop-color="#2DD4BF"/><stop offset="1" stop-color="#7C5CFF"/></linearGradient></defs></svg></div>
                    <h3>Science</h3>
                    <p>Ideas, discovery, and curiosity.</p>
                </a>
                <a href="/category/Business" class="category-card" style="--category-image: url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=900&q=90');" data-aos="zoom-in" data-aos-delay="500">
                    <div class="category-icon"><svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="11" y="23" width="42" height="24" rx="8" fill="url(#g6)"/><path d="M23 23V18C23 14.6863 25.6863 12 29 12H35C38.3137 12 41 14.6863 41 18V23" stroke="white" stroke-width="3"/><path d="M25 35H39" stroke="white" stroke-width="3" stroke-linecap="round"/><defs><linearGradient id="g6" x1="11" x2="53" y1="23" y2="47"><stop stop-color="#7C5CFF"/><stop offset="1" stop-color="#2DD4BF"/></linearGradient></defs></svg></div>
                    <h3>Business</h3>
                    <p>Strategy, growth, and creative leadership.</p>
                </a>
                <a href="/category/Health" class="category-card" style="--category-image: url('https://images.unsplash.com/photo-1490645935967-10de6ba17061?w=900&q=90');" data-aos="zoom-in" data-aos-delay="600">
                    <div class="category-icon"><svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="14" y="16" width="36" height="32" rx="12" fill="url(#g7)"/><path d="M32 24V40" stroke="white" stroke-width="3" stroke-linecap="round"/><path d="M25 32H39" stroke="white" stroke-width="3" stroke-linecap="round"/><defs><linearGradient id="g7" x1="14" x2="50" y1="16" y2="48"><stop stop-color="#2DD4BF"/><stop offset="1" stop-color="#7C5CFF"/></linearGradient></defs></svg></div>
                    <h3>Health</h3>
                    <p>Wellness, balance, and mindful living.</p>
                </a>
                <a href="/category/Education" class="category-card" style="--category-image: url('https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=900&q=90');" data-aos="zoom-in" data-aos-delay="700">
                    <div class="category-icon"><svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M32 12L50 24L32 36L14 24L32 12Z" fill="url(#g8)"/><path d="M20 28V41" stroke="white" stroke-width="3" stroke-linecap="round"/><path d="M32 36V49" stroke="white" stroke-width="3" stroke-linecap="round"/><path d="M44 28V41" stroke="white" stroke-width="3" stroke-linecap="round"/><defs><linearGradient id="g8" x1="14" x2="50" y1="12" y2="36"><stop stop-color="#7C5CFF"/><stop offset="1" stop-color="#2DD4BF"/></linearGradient></defs></svg></div>
                    <h3>Education</h3>
                    <p>Learning, growth, and thoughtful insight.</p>
                </a>
            </div>
            <div class="categories-explore-wrap" data-aos="fade-up" data-aos-delay="150">
                <a href="/blog/list#allCategoriesNav" class="btn btn-secondary categories-explore-btn">Explore More</a>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>

