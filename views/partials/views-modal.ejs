<div class="views-modal" id="viewsModal" aria-hidden="true" role="dialog" aria-labelledby="viewsModalTitle">
    <div class="views-modal-backdrop" data-close-modal></div>
    <div class="views-modal-panel">
        <div class="views-modal-header">
            <h3 id="viewsModalTitle">Post Viewers</h3>
            <button type="button" class="views-modal-close" data-close-modal aria-label="Close">&times;</button>
        </div>
        <div class="views-modal-body" id="viewsModalBody">
            <p class="views-modal-loading">Loading viewers...</p>
        </div>
    </div>
</div>
