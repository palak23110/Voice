<% const commentCount = typeof blog.commentCount !== 'undefined' ? blog.commentCount : 0; %>
<% const blogId = blog._id; %>
<% const publishedDate = blog.createdAt ? new Date(blog.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : ''; %>
<div class="blog-card" data-blog-id="<%= blogId %>" data-category="<%= blog.category %>">
    <div class="blog-card-image">
        <img src="<%= blog.imageUrl || '/images/default-blog.jpg' %>" alt="<%= blog.title %>" loading="lazy">
        <span class="blog-category"><%= blog.category %></span>
    </div>
    <div class="blog-card-content">
        <h3 class="blog-card-title"><a href="/blog/<%= blogId %>"><%= blog.title %></a></h3>
        <p class="blog-card-excerpt"><%= blog.excerpt %></p>
        <div class="blog-card-footer">
            <div class="blog-card-byline">
                <span class="blog-author">By <%= blog.author %></span>
                <% if (publishedDate) { %>
                    <span class="blog-date"><%= publishedDate %></span>
                <% } %>
            </div>
            <div class="blog-card-engagement">
                <button type="button" class="blog-views blog-views-trigger" data-blog-id="<%= blogId %>" aria-label="View who read this post">👁 <%= blog.views || 0 %> Views</button>
                <a href="/blog/<%= blogId %>?comments=1#comments" class="blog-comments-link">💬 <%= commentCount %> Comments</a>
            </div>
        </div>
        <% if (blog.tags && blog.tags.length > 0) { %>
            <div class="blog-card-tags">
                <% blog.tags.slice(0, 3).forEach(tag => { %>
                    <span class="tag"><%= tag %></span>
                <% }); %>
            </div>
        <% } %>
    </div>
</div>
