<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/profile.css">
<main class="profile-page">
    <div class="profile-container profile-help-container">
        <div class="help-shell">
            <div class="help-header">
                <div>
                    <p class="eyebrow">Help Center</p>
                    <h1>Need support?</h1>
                    <p class="help-description">Browse frequently asked questions or reach out to our support team for help with your profile and publishing workflow.</p>
                </div>
                <a href="/profile" class="btn btn-secondary">Back to Profile</a>
            </div>

            <div class="help-grid">
                <section class="help-card panel-card">
                    <h2>FAQ</h2>
                    <div class="faq-item">
                        <h3>How do I edit my profile?</h3>
                        <p>Go to Settings from the sidebar and update your username, bio, avatar, or cover image.</p>
                    </div>
                    <div class="faq-item">
                        <h3>How do I publish a new blog?</h3>
                        <p>Use the Write Blog link in the navbar and create a new post from the editor.</p>
                    </div>
                    <div class="faq-item">
                        <h3>Can I change my password?</h3>
                        <p>Yes. Use the Security fields in Settings to update your password securely.</p>
                    </div>
                </section>

                <section class="help-card panel-card contact-card">
                    <h2>Contact Support</h2>
                    <p>If you need help with your account or a published article, our support team is here for you.</p>
                    <div class="contact-details">
                        <div><strong>Email</strong><span>palakgupta792383@gmail.com</span></div>
                        <div><strong>Response time</strong><span>Within 24 hours</span></div>
                    </div>
                    <a href="mailto:support@voices.example" class="btn btn-primary">Email Support</a>
                </section>
            </div>
        </div>
    </div>
</main>
<%- include('../partials/footer') %>
