<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/profile.css">
<main class="profile-page">
    <div class="profile-container profile-settings-container">
        <div class="settings-shell">
            <div class="settings-header">
                <div>
                    <p class="eyebrow">Profile Settings</p>
                    <h1>Account preferences</h1>
                    <p class="profile-settings-description">Update your profile, avatar, cover image, and security settings in one place.</p>
                </div>
                <a href="/profile" class="btn btn-secondary">Back to Profile</a>
            </div>

            <% if (error) { %>
                <div class="settings-message error"><%= error %></div>
            <% } %>
            <% if (success) { %>
                <div class="settings-message success"><%= success %></div>
            <% } %>

            <form action="/profile/settings" method="POST" class="settings-form">
                <div class="settings-grid">
                    <div class="settings-card">
                        <h2>Account</h2>
                        <label>Username</label>
                        <input type="text" name="username" value="<%= profileUser.username %>" required>

                        <label>Email</label>
                        <input type="email" name="email" value="<%= profileUser.email %>" required>

                        <label>Bio</label>
                        <textarea name="bio" rows="4"><%= profileUser.bio || '' %></textarea>

                        <label>Avatar URL</label>
                        <input type="text" name="avatarUrl" value="<%= profileUser.avatarUrl || '' %>">

                        <label>Cover Image URL</label>
                        <input type="text" name="coverImageUrl" value="<%= profileUser.coverImageUrl || '' %>">
                    </div>

                    <div class="settings-card">
                        <h2>Security</h2>
                        <label>Current Password</label>
                        <input type="password" name="currentPassword" placeholder="Leave blank to keep current password">

                        <label>New Password</label>
                        <input type="password" name="newPassword" placeholder="Enter new password">

                        <label>Confirm New Password</label>
                        <input type="password" name="confirmPassword" placeholder="Confirm new password">
                    </div>
                </div>

                <div class="settings-actions">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</main>
<%- include('../partials/footer') %>
