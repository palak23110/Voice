<%- include('../partials/header') %>

<main class="main-content page-blog-list">
    <div class="page-hero-bg"></div>
    <div class="page-hero-overlay"></div>
    
    <div class="container">
        <div class="page-header" data-aos="fade-up">
            <h1>All Blogs</h1>
            <p>Discover perspectives from voices around the world</p>
        </div>

        <div class="filter-section" data-aos="fade-up" data-aos-delay="100">
            <div class="search-box">
                <input type="text" id="searchInput" placeholder="Search blogs by title, content, tags, or category...">
                <button id="searchBtn" class="btn btn-primary">Search</button>
            </div>

            <div class="category-nav-section" id="allCategoriesNav">
                <h3 class="category-nav-heading">All Categories</h3>
                <div class="category-nav-bar" id="categoryNavBar">
                    <button type="button" class="category-nav-arrow category-nav-prev is-hidden" id="categoryNavPrev" aria-label="Previous categories">‹</button>
                    <div class="category-nav-track-wrap" id="categoryNavWrap">
                        <div class="category-nav-track" id="categoryNavTrack">
                            <a href="/blog/list" class="category-nav-chip <%= !category ? 'active' : '' %>">All</a>
                            <% if (typeof categories !== 'undefined') { %>
                                <% categories.forEach(cat => { %>
                                    <a href="/blog/list?category=<%= encodeURIComponent(cat.slug) %>" 
                                       class="category-nav-chip <%= category && (category === cat.name || category === cat.slug) ? 'active' : '' %>">
                                        <%= cat.name %>
                                    </a>
                                <% }); %>
                            <% } %>
                        </div>
                    </div>
                    <button type="button" class="category-nav-arrow category-nav-next is-hidden" id="categoryNavNext" aria-label="Next categories">›</button>
                </div>
            </div>
        </div>

        <div class="blogs-grid" id="blogsGrid" data-aos="fade-up" data-aos-delay="200">
            <% if (blogs && blogs.length > 0) { %>
                <% blogs.forEach(blog => { %>
                    <%- include('../partials/blog-card', { blog }) %>
                <% }); %>
            <% } else { %>
                <p class="no-blogs">No blogs found. <a href="/blog/create/new">Be the first to write!</a></p>
            <% } %>
        </div>

        <% if (totalPages > 1) { %>
            <div class="pagination" data-aos="fade-up">
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage - 1 %><%= category ? '&category=' + encodeURIComponent(category) : '' %>" class="pagination-btn">Previous</a>
                <% } %>
                <% for (let i = 1; i <= totalPages; i++) { %>
                    <a href="?page=<%= i %><%= category ? '&category=' + encodeURIComponent(category) : '' %>" 
                       class="pagination-btn <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
                <% } %>
                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %><%= category ? '&category=' + encodeURIComponent(category) : '' %>" class="pagination-btn">Next</a>
                <% } %>
            </div>
        <% } %>
    </div>
</main>

<%- include('../partials/views-modal') %>
<%- include('../partials/footer') %>
<script src="/js/categoryBar.js"></script>
<script src="/js/blogInteractions.js"></script>
