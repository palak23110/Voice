<%- include('../partials/header') %>

<main class="main-content page-blog-detail">
    <% if (typeof blog !== 'undefined' && blog) { %>
    <% const bannerImage = blog.imageUrl || 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1920&q=80'; %>
    <% const categoryHref = blog.categorySlug ? '/category/' + blog.categorySlug : '/category/' + encodeURIComponent(blog.category); %>
    <div class="blog-banner-bg" style="background-image: url('<%= bannerImage %>');"></div>
    <div class="blog-banner-overlay"></div>
    
    <div class="container">
        <article class="blog-detail" data-aos="fade-up">
            <div class="blog-header">
                <a href="<%= categoryHref %>" class="blog-category-badge"><%= blog.category || 'Uncategorized' %></a>
                <h1 class="blog-title"><%= blog.title || 'Untitled Blog' %></h1>
                <div class="blog-meta">
                    <span class="blog-author">By <strong><%= blog.author || 'Anonymous' %></strong></span>
                    <span class="blog-date"><%= blog.createdAt ? new Date(blog.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'Date unknown' %></span>
                    <button type="button" class="blog-meta-action blog-views-trigger" data-blog-id="<%= blog._id %>" aria-label="View readers">
                        👁 <%= blog.views || 0 %> views
                    </button>
                    <a href="#comments" class="blog-meta-action">💬 <%= typeof commentCount !== 'undefined' ? commentCount : (comments ? comments.length : 0) %> comments</a>
                </div>
            </div>

            <div class="blog-image" data-aos="zoom-in" data-aos-delay="100">
                <img src="<%= blog.imageUrl || 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1920&q=80' %>" alt="<%= blog.title || 'Blog Image' %>" onerror="this.src='https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1920&q=80'">
            </div>

            <div class="blog-content">
                <div class="blog-body" data-aos="fade-up" data-aos-delay="200">
                    <%- (blog.content || 'Content coming soon...').replace(/\n/g, '<br>') %>
                </div>

                <% if (blog.tags && blog.tags.length > 0) { %>
                    <div class="blog-tags" data-aos="fade-up" data-aos-delay="300">
                        <strong>Tags:</strong>  
                        <% blog.tags.forEach(tag => { %>
                            <span class="tag"><%= tag %></span>
                        <% }); %>
                    </div>
                <% } %>

                <div class="blog-actions" data-aos="fade-up" data-aos-delay="400">
                    <% if (typeof user !== 'undefined' && user && user.id === blog.authorId.toString()) { %>
                        <a href="/blog/edit/<%= blog._id %>" class="btn btn-secondary">Edit Blog</a>
                        <form action="/blog/delete/<%= blog._id %>" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this blog?');">
                            <button type="submit" class="btn btn-danger">Delete Blog</button>
                        </form>
                    <% } %>
                </div>
            </div>
        </article>

        <section class="comments-section" id="comments" data-blog-id="<%= blog._id %>" data-aos="fade-up" data-aos-delay="100">
            <h2>Comments (<span id="commentCountDisplay"><%= typeof commentCount !== 'undefined' ? commentCount : (comments ? comments.length : 0) %></span>)</h2>
            
            <% if (typeof user !== 'undefined' && user) { %>
                <form action="/blog/<%= blog._id %>/comment" method="POST" class="comment-form">
                    <textarea name="content" placeholder="Share your thoughts..." required></textarea>
                    <button type="submit" class="btn btn-primary">Post Comment</button>
                </form>
            <% } else { %>
                <p class="login-prompt">Please <a href="/auth/login">login</a> to post a comment.</p>
            <% } %>

            <div class="comments-list" id="commentsList">
                <% if (comments && comments.length > 0) { %>
                    <% comments.forEach((comment, index) => { %>
                        <% const profileUrl = '/profile?u=' + encodeURIComponent(comment.author); %>
                        <% const avatar = comment.authorImage || ''; %>
                        <article class="comment-item" data-aos="fade-up" data-aos-delay="<%= index * 50 %>">
                            <div class="comment-header">
                                <a href="<%= profileUrl %>" class="comment-avatar-link">
                                    <% if (avatar) { %>
                                        <img src="<%= avatar %>" alt="<%= comment.author %>" class="comment-avatar">
                                    <% } else { %>
                                        <span class="comment-avatar comment-avatar-fallback"><%= comment.author.charAt(0).toUpperCase() %></span>
                                    <% } %>
                                </a>
                                <div class="comment-meta">
                                    <a href="<%= profileUrl %>" class="comment-author-name"><%= comment.author %></a>
                                    <time class="comment-timestamp" datetime="<%= comment.createdAt %>">
                                        <%= new Date(comment.createdAt).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %>
                                    </time>
                                </div>
                            </div>
                            <p class="comment-content"><%= comment.content %></p>
                        </article>
                    <% }); %>
                <% } else { %>
                    <p class="no-comments">No comments yet. Be the first to share your thoughts!</p>
                <% } %>
            </div>
        </section>

        <% if (relatedBlogs && relatedBlogs.length > 0) { %>
            <section class="related-blogs" data-aos="fade-up" data-aos-delay="200">
                <h2>Related Blogs</h2>
                <div class="blogs-grid">
                    <% relatedBlogs.forEach(relatedBlog => { %>
                        <%- include('../partials/blog-card', { blog: relatedBlog }) %>
                    <% }); %>
                </div>
            </section>
        <% } %>
    </div>
    <% } else { %>
    <div class="container">
        <div class="error-container">
            <div class="error-content" data-aos="zoom-in">
                <h1>Oops!</h1>
                <p class="error-message">Blog content is not available at this time.</p>
                <a href="/blog/list" class="btn btn-primary">Browse All Blogs</a>
            </div>
        </div>
    </div>
    <% } %>
</main>

<%- include('../partials/views-modal') %>
<%- include('../partials/footer') %>
<script src="/js/blogInteractions.js"></script>
<% if (typeof scrollToComments !== 'undefined' && scrollToComments) { %>
<script>document.addEventListener('DOMContentLoaded', () => document.getElementById('comments')?.scrollIntoView({ behavior: 'smooth' }));</script>
<% } %>
<script>
document.addEventListener('DOMContentLoaded', function() {
    if (window.location.hash === '#comments') {
        document.getElementById('comments')?.scrollIntoView({ behavior: 'smooth' });
    }
});
</script>
